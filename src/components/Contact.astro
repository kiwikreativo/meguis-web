---
import { Phone, Mail, MapPin, Send } from "@lucide/astro";
---

<div class="container-fluid" id="contact">
  <div class="container">
    <div class="row">
      <div class="col-6">
        <div class="entitle">
          <div class="mail-entitle" >
              <div class="icon-entitle">
                <Mail size={12} />
              </div>
              <span class="data-entile">Comencemos</span>
          </div>
          <h1 class="contact-title">Construyamos su Futuro Logistico</h1>
          <p class="entitle-text">
            Tiene un proyecto en mente o necesita asesoría logística?
Complete el formulario y nuestro equipo se pondrá en contacto con usted a la mayor brevedad. Le brindaremos una atención personalizada para entender sus necesidades y ofrecer la mejor solución en logística, aduanas y comercio internacional. Estamos listos para acompañarle en cada paso de su operación.
          </p>
        </div>
        <div class="contact-info">
          <div class="group-1">
            <div class="contact-item phone">
              <div class="icon">
                <Phone size={18} />
              </div>
              <span class="contact-data">+504 963808889</span>
            </div>
            <div class="contact-item mail">
              <div class="icon">
                <Mail size={18} />
              </div>
              <span class="contact-data">info@meguis.com</span>
            </div>
          </div>
          <div class="contact-item location">
            <div class="icon">
              <MapPin size={18} />
            </div>
            <span class="contact-data">San Pedro Sula, Honduras</span>
          </div>
        </div>
      </div>
      <div class="col-6 form-submit">
        <form name="contact" data-netlify="true">
          <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input
              type="text"
              name="name"
              class="form-control"
              placeholder="John Doe"
            />
          </div>
          <div class="mb-3">
            <label class="form-label"
              >Correo</label
            >
            <input
              type="email"
              name="email"
              class="form-control"
              aria-describedby="emailHelp"
              placeholder="johndoe@gmail.com"
              required
            />
          </div>
          <div class="mb-3 select-service">
            <label class="form-label">Servicio</label>
            <select class="form-select" aria-label="Default Seleccione un servicio" name="service[]" >
              <option value="">Seleccione un servicio</option>
              <option value="Logística Integral">Logística Integral</option>
              <option value="Transporte Terrestre">Transporte Terrestre</option>
              <option value="Asesoría Legal Aduanera">Asesoría Legal Aduanera</option>
            </select>
          </div>
          <div class="mb-3 message">
            <label class="form-label">Mensaje</label>
            <textarea
              class="form-control"
              rows="3"
              placeholder="Escriba su mensaje aquí..."
              name="message"
            ></textarea>
          </div>
          <button type="submit" class="btn btn-primary"> 
            <div class="icon">
              <Send size={18} /> 
            </div>
            Enviar</button>
        </form>
      </div>
    </div>
  </div>
</div>

<style>
  .container-fluid {
    width: 100%;
    min-height: 95vh;
    background-color: #011223;
    padding: 60px 0;
    box-sizing: border-box;
  }

  .container {
    width: min(1200px, 90%);
    margin: 0 auto;
  }

  .row {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    background-color: #0b223f;
    color: white;
    padding: 20px;
    border-radius: 20px;
    width: 100%;
    margin: 0 auto;
    gap: 24px;
    box-sizing: border-box;
  }

  .entitle {
    margin-top: 10%;
    margin-left: 5%;
    width: 100%;
    max-width: 560px;
  }

  .mail-entitle {
    display: flex;
    align-items: center;
    background-color: rgba(255, 183, 3, 0.1);
    width: 130px;
    border-radius: 50px;
    padding: 5px;
    border: 2px solid #e36414;
    margin-bottom: 20px;
  }

  .data-entile {
    font-size: 12px;
    color: rgba(255, 183, 3, 1);
    margin-left: 5%;
  }

  .icon-entitle {
    background-color: #fefdfd;
    color: black;
    border-radius: 50%;
    padding: 5px;
    margin-right: 10px;
  }
  

  .contact-title {
    font-size: 40px;
    font-weight: bold;
    margin-bottom: 10px;
    line-height: 1.1;
  }

  .entitle-text {
    font-size: 16px;
    color: grey;
  }

  .contact-info {
    margin-top: 60px;
    margin-left: 5%;
    margin-bottom: 24px;
  }

  .group-1 {
    display: flex;
    flex-wrap: wrap;
    gap: 30px;
    margin-bottom: 18px;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .location {
    margin-top: 0;
  }

  .icon {
    background-color: #fefdfd;
    color: black;
    border-radius: 50%;
    padding: 8px;
    min-width: 36px;
  }

  .contact-data {
    font-size: 13px;
    color: white;
  }

  /* Column Form */

  .form-submit{
    background-color: rgba(243, 91, 4, 1);
    padding: 30px;
    width: 100%;
    max-width: 520px;
    border-radius: 20px;
    box-sizing: border-box;
    margin-right: 2%;
  }

  .form-submit label {
    text-transform: uppercase;
    font-weight: bold;
    margin-left: 5%;
  }

  .form-submit input{
    display:flex;
    margin: 2% auto;
    flex-direction: column;
    background-color: rgba(241, 135, 1, 1);
    width: 90%;
    padding: 15px;
    border-radius: 10px;
    color: black;
  }

  .form-submit input:focus{
    outline: none;
    border: 2px solid #fefdfd;
  }



  .form-submit select{
    display:flex;
    margin: 2% auto;
    flex-direction: column;
    background-color: rgba(241, 135, 1, 1);
    width: 90%;
    padding: 18px;
    border-radius: 10px;
    color: black;
  }

  .form-submit textarea{
    display:flex;
    margin: 2% auto;
    flex-direction: column;
    background-color: rgba(241, 135, 1, 1);
    width: 90%;
    padding: 15px;
    border-radius: 10px;
    color: black;
    resize: none;
    auto-grow: true;
  }

  .form-submit textarea:focus{
    outline: none;
    border: 2px solid #fefdfd;
  }

  .form-submit button{
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-left: 5%;
    margin-top: 5%;
    background-color: #011223;
    width: auto;
    min-width: 120px;
    min-height: 50px;
    /* top right bottom left */
    padding: 10px 14px 10px 0;
    border-radius: 25px;
    color: white;
    font-weight: bold;
    gap: 12px;
  }

  @media (max-width: 900px) {
    .row {
      flex-direction: column;
      padding: 24px;
    }

    .col-6 {
      width: 100%;
    }

    .entitle {
      max-width: 100%;
    }

    
    .contact-title {
      font-size: 32px;
    }

    .form-submit {
      width: 100%;
      padding: 24px;
    }

    .form-submit input,
    .form-submit select,
    .form-submit textarea {
      width: 100%;
      margin: 12px 0;
    }

    .form-submit button {
      margin-left: 0;
      width: 100%;
    }
  }


 

</style>
