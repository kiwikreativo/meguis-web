---
import { Phone, Mail, MapPin, Send } from "@lucide/astro";
---

<div class="container-fluid">
  <div class="container">
    <div class="row">
      <div class="col-6">
        <div class="entitle">
          <div class="mail-entitle" >
              <div class="icon-entitle">
                <Mail size={12} />
              </div>
              <span class="data-entile">Comencemos</span>
          </div>
          <h1 class="contact-title">Construyamos su Futuro Logistico</h1>
          <p class="entitle-text">
            ¿Listo para optimizar sus operaciones? Complete el formulario y nos
            pondremos en contacto con usted.
          </p>
        </div>
        <div class="contact-info">
          <div class="group-1" style="display: flex; align-items: center;">
            <div class="phone" style="display: flex; align-items: center;">
              <div class="icon">
                <Phone size={18} />
              </div>
              <span class="contact-data">+504 963808889</span>
            </div>
            <div class="mail" style="display: flex; align-items: center;">
              <div class="icon">
                <Mail size={18} />
              </div>
              <span class="contact-data">info@meguis.com</span>
            </div>
          </div>
          <div class="location" style="display: flex; align-items: center;">
            <div class="icon">
              <MapPin size={18} />
            </div>
            <span class="contact-data">San Pedro Sula, Honduras</span>
          </div>
        </div>
      </div>
      <div class="col-6 form-submit">
        <form>
          <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input
              type="text"
              class="form-control"
              placeholder="John Doe"
            />
          </div>
          <div class="mb-3">
            <label class="form-label"
              >Correo</label
            >
            <input
              type="email"
              class="form-control"
              aria-describedby="emailHelp"
              placeholder="johndoe@gmail.com"
              required
            />
          </div>
          <div class="mb-3 select-service">
            <label class="form-label">Servicio</label>
            <select class="form-select" aria-label="Default Seleccione un servicio">
              <option>Seleccione un servicio</option>
              <option>Logística Integral</option>
              <option>Transporte Terrestre</option>
              <option>Asesoría Legal Aduanera</option>
            </select>
          </div>
          <div class="mb-3 message">
            <label class="form-label">Mensaje</label>
            <textarea
              class="form-control"
              rows="3"
              placeholder="Escriba su mensaje aquí..."
            ></textarea>
          </div>
          <button type="submit" class="btn btn-primary"> 
            <div class="icon">
              <Send size={18} /> 
            </div>
            Submit</button>
        </form>
      </div>
    </div>
  </div>
</div>

<style>
  .container-fluid {
    width: 100%;
    height: 95vh;
    background-color: #011223;
  }

  .container {
    width: 80%;
    margin: 0  auto;
  }

  .row {
    display: flex;
    justify-content: space-between;
    background-color: #012f47;
    color: white;
    padding: 20px;
    border-radius: 20px;
    width: 90%;
    margin: 100px auto;
  }

  .entitle {
    margin-top: 6%;
    margin-left: 2%;
    width: 95%;
  }

  .mail-entitle {
    display: flex;
    align-items: center;
    background-color: rgba(255, 183, 3, 0.1);
    width: 130px;
    border-radius: 50px;
    padding: 5px;
    border: 2px solid #e36414;
    margin-bottom: 20px;
  }

  .data-entile {
    font-size: 12px;
    color: rgba(255, 183, 3, 1);
  }

  .icon-entitle {
    background-color: #fefdfd;
    color: black;
    border-radius: 50%;
    padding: 5px;
    margin-right: 10px;
  }
  

  .contact-title {
    font-size: 40px;
    font-weight: bold;
    margin-bottom: 10px;
    line-height: 1.1;
  }

  .entitle-text {
    font-size: 16px;
    color: grey;
  }

  .contact-info {
    margin-top: 40%;
    margin-left: 2%;
    margin-bottom: 4%;
  }

  .group-1 {
    display: flex;
    gap: 30px;
    margin-bottom: 15px;
  }

  .icon {
    background-color: #fefdfd;
    color: black;
    border-radius: 50%;
    padding: 8px;
    margin-right: 10px;
  }

  .contact-data {
    font-size: 13px;
    color: white;
  }

  /* Column Form */

  .form-submit{
    background-color: rgba(243, 91, 4, 1);
    padding: 30px;
    width: 60%;
    border-radius: 20px;
    
  }

  .form-submit label {
    text-transform: uppercase;
    font-weight: bold;
    margin-left: 5%;
  }

  .form-submit input{
    display:flex;
    margin: 2% auto;
    flex-direction: column;
    background-color: rgba(241, 135, 1, 1);
    width: 90%;
    padding: 15px;
    border-radius: 10px;
    color: black;
  }

  .form-submit input:focus{
    outline: none;
    border: 2px solid #fefdfd;
  }



  .form-submit select{
    display:flex;
    margin: 2% auto;
    flex-direction: column;
    background-color: rgba(241, 135, 1, 1);
    width: 90%;
    padding: 18px;
    border-radius: 10px;
    color: black;
  }

  .form-submit textarea{
    display:flex;
    margin: 2% auto;
    flex-direction: column;
    background-color: rgba(241, 135, 1, 1);
    width: 90%;
    padding: 15px;
    border-radius: 10px;
    color: black;
    resize: none;
    auto-grow: true;
  }

  .form-submit textarea:focus{
    outline: none;
    border: 2px solid #fefdfd;
  }

  .form-submit button{
    display: flex;
    margin-left: 5%;
    margin-top: 5%;
    background-color: #011223;
    width: 33%;
    padding: 25px;
    border-radius: 25px;
    color: white;
    font-weight: bold;
  }

  @media (min-width: 320px) and (max-width: 768px) {
    .row {
      display: flex;
      flex-direction: column;
    }
  }

</style>
